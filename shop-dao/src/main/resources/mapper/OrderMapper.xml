<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shop.demo.dao.mapper.OrderMapper">

    <resultMap id="BaseResultMap" type="com.shop.demo.model.entity.Order">
        <id column="id" property="id"/>
        <result column="order_no" property="orderNo"/>
        <result column="user_id" property="userId"/>
        <result column="receiver_name" property="receiverName"/>
        <result column="receiver_phone" property="receiverPhone"/>
        <result column="receiver_address" property="receiverAddress"/>
        <result column="total_amount" property="totalAmount"/>
        <result column="status" property="status"/>
        <result column="pay_type" property="payType"/>
        <result column="pay_time" property="payTime"/>
        <result column="ship_time" property="shipTime"/>
        <result column="finish_time" property="finishTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM orders
        WHERE id = #{id}
    </select>

    <select id="selectByOrderNo" resultMap="BaseResultMap">
        SELECT * FROM orders
        WHERE order_no = #{orderNo}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT * FROM orders
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO orders (order_no, user_id, receiver_name, receiver_phone, receiver_address,
                           total_amount, status, pay_type, create_time, update_time)
        VALUES (#{orderNo}, #{userId}, #{receiverName}, #{receiverPhone}, #{receiverAddress},
                #{totalAmount}, #{status}, #{payType}, NOW(), NOW())
    </insert>

    <update id="updateById">
        UPDATE orders
        <set>
            <if test="order.status != null">status = #{order.status},</if>
            <if test="order.payTime != null">pay_time = #{order.payTime},</if>
            <if test="order.shipTime != null">ship_time = #{order.shipTime},</if>
            <if test="order.finishTime != null">finish_time = #{order.finishTime},</if>
            update_time = NOW()
        </set>
        WHERE id = #{order.id}
    </update>

    <update id="deleteById">
        UPDATE orders
        SET update_time = NOW()
        WHERE id = #{id}
    </update>

</mapper>

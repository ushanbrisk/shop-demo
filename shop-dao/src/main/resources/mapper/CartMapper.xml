<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shop.demo.dao.mapper.CartMapper">

    <resultMap id="BaseResultMap" type="com.shop.demo.model.entity.Cart">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="product_id" property="productId"/>
        <result column="quantity" property="quantity"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT * FROM carts
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
    </select>

    <select id="selectByUserIdAndProductId" resultMap="BaseResultMap">
        SELECT * FROM carts
        WHERE user_id = #{userId} AND product_id = #{productId}
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM carts
        WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO carts (user_id, product_id, quantity, create_time, update_time)
        VALUES (#{userId}, #{productId}, #{quantity}, NOW(), NOW())
    </insert>

    <update id="updateById">
        UPDATE carts
        <set>
            <if test="cart.quantity != null">quantity = #{cart.quantity},</if>
            update_time = NOW()
        </set>
        WHERE id = #{cart.id}
    </update>

    <delete id="deleteById">
        DELETE FROM carts WHERE id = #{id}
    </delete>

    <delete id="deleteByUserId">
        DELETE FROM carts WHERE user_id = #{userId}
    </delete>

</mapper>
